# Google Sheets
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

# Telegram уведомления
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Расписание
SEND_HOUR=12
SEND_MINUTE=0
CHECK_REPLIES_INTERVAL_MINUTES=60
DAYS_BETWEEN_MESSAGES=1
# Keepalive сессии Циан — продление DMIR_AUTH через браузер (дней)
KEEPALIVE_INTERVAL_DAYS=7

# Циан
CIAN_SESSION_FILE=cian_session.json
# Транспорт отправки: browser (через Playwright, надёжнее) или api (через HTTP API Циана)
SEND_VIA=browser

# SOCKS5 прокси (если Telegram заблокирован на VPS)
# SOCKS5_PROXY=host:port
